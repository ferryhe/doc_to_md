# Copy to .env and fill secrets
MISTRAL_API_KEY=
SILICONFLOW_API_KEY=
MATHPIX_APP_ID=
MATHPIX_APP_KEY=
DEFAULT_ENGINE=local
MISTRAL_DEFAULT_MODEL=mistral-ocr-latest
SILICONFLOW_DEFAULT_MODEL=deepseek-ai/DeepSeek-OCR
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
MISTRAL_TIMEOUT_SECONDS=60
MISTRAL_RETRY_ATTEMPTS=3
MISTRAL_MAX_PDF_TOKENS=9000
MISTRAL_MAX_PAGES_PER_CHUNK=25
SILICONFLOW_TIMEOUT_SECONDS=60
SILICONFLOW_RETRY_ATTEMPTS=3
SILICONFLOW_MAX_INPUT_TOKENS=3500
SILICONFLOW_CHUNK_OVERLAP_TOKENS=200
MATHPIX_TIMEOUT_SECONDS=120
MATHPIX_RETRY_ATTEMPTS=3
MATHPIX_POLL_INTERVAL_SECONDS=5
MATHPIX_OUTPUT_FORMAT=md
MARKITDOWN_ENABLE_PLUGINS=true
MARKITDOWN_ENABLE_BUILTINS=true
PADDLEOCR_LANG=en
PADDLEOCR_RENDER_DPI=220
PADDLEOCR_MAX_PAGES=
DOCLING_MAX_PAGES=
DOCLING_RAISE_ON_ERROR=true
MINERU_BACKEND=pipeline
MINERU_PARSE_METHOD=auto
MINERU_LANG=en
MINERU_FORMULA_ENABLE=true
MINERU_TABLE_ENABLE=true
MINERU_START_PAGE=0
MINERU_END_PAGE=
MINERU_SERVER_URL=
MINERU_PRO_MODEL=opendatalab/MinerU2.5-Pro-2604-1.2B
MINERU_PRO_BACKEND=http-client
MINERU_PRO_SERVER_URL=
MINERU_PRO_RENDER_DPI=200
MINERU_PRO_MAX_PAGES=
MINERU_PRO_IMAGE_ANALYSIS=false
MARKER_USE_LLM=false
MARKER_PROCESSORS=
MARKER_PAGE_RANGE=
MARKER_EXTRACT_IMAGES=true
MARKER_LLM_SERVICE=
FORMULA_OCR_ENABLED=false
FORMULA_OCR_PROVIDER=mistral
# Auto-engine per-format routing (used when DEFAULT_ENGINE=auto)
AUTO_PDF_ENGINE=local
AUTO_DOCX_ENGINE=local
AUTO_PPTX_ENGINE=local
AUTO_SPREADSHEET_ENGINE=local
AUTO_HTML_ENGINE=html_local
AUTO_IMAGE_ENGINE=local
AUTO_TEXT_ENGINE=local
